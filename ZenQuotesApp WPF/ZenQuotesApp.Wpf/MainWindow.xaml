<Window x:Class="ZenQuotesApp.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ZenQuotesApp.Wpf"
        mc:Ignorable="d"
        Title="ZenQuotes" Height="660" Width="1020" MinHeight="540" MinWidth="840"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Background="{StaticResource BgBrush}"
        WindowStyle="None"
        ResizeMode="CanResize">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" ResizeBorderThickness="6" CornerRadius="0"
                      GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Полоса заголовка (кастомная) -->
        <Grid Grid.Row="0" Background="#000000">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                <Ellipse Width="16" Height="16" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                <TextBlock Text="ZenQuotes" Foreground="White" FontWeight="Bold" FontSize="13"
                           Margin="8,0,0,0" VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="MinimizeButton" Click="MinimizeButton_Click" Content="&#xE921;"
                        FontFamily="Segoe MDL2 Assets" FontSize="10"
                        Style="{StaticResource TitleBarButtonStyle}"
                        WindowChrome.IsHitTestVisibleInChrome="True" />
                <Button x:Name="MaximizeButton" Click="MaximizeButton_Click"
                        FontFamily="Segoe MDL2 Assets" FontSize="10"
                        Style="{StaticResource TitleBarButtonStyle}"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock x:Name="MaximizeGlyph" Text="&#xE922;" />
                </Button>
                <Button x:Name="CloseButton" Click="CloseButton_Click" Content="&#xE8BB;"
                        FontFamily="Segoe MDL2 Assets" FontSize="10"
                        Style="{StaticResource CloseButtonStyle}"
                        WindowChrome.IsHitTestVisibleInChrome="True" />
            </StackPanel>
        </Grid>

        <!-- Основная область -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Сайдбар -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
                <StackPanel Margin="14,24">
                    <Button Content="Главная" Style="{StaticResource NavButtonStyle}"
                            Command="{Binding NavigateCommand}" CommandParameter="Home" />
                    <Button Content="Поиск" Style="{StaticResource NavButtonStyle}"
                            Command="{Binding NavigateCommand}" CommandParameter="Search" />
                    <Button Content="Игра" Style="{StaticResource NavButtonStyle}"
                            Command="{Binding NavigateCommand}" CommandParameter="Game" />
                    <Button Content="Библиотека" Style="{StaticResource NavButtonStyle}"
                            Command="{Binding NavigateCommand}" CommandParameter="Library" />
                    <Button Content="Настройки" Style="{StaticResource NavButtonStyle}"
                            Command="{Binding NavigateCommand}" CommandParameter="Settings" />
                </StackPanel>
            </Border>

            <!-- Контент -->
            <Grid Grid.Column="1" Margin="36,28">

                <!-- Главная -->
                <Grid Visibility="{Binding IsHome, Converter={StaticResource BoolToVis}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="660">
                        <TextBlock Text="Цитата дня" Style="{StaticResource SubText}" Margin="2,0,0,10" />
                        <Border Style="{StaticResource CardStyle}" Padding="40">
                            <StackPanel>
                                <TextBlock Style="{StaticResource QuoteText}">
                                    <Run Text="“" /><Run Text="{Binding CurrentRandom.Text}" /><Run Text="”" />
                                </TextBlock>
                                <TextBlock Text="{Binding CurrentRandom.Author}" Style="{StaticResource AuthorText}"
                                           Margin="0,20,0,0" />
                            </StackPanel>
                        </Border>
                        <Button Content="Следующая цитата" Style="{StaticResource AccentButtonStyle}"
                                Command="{Binding NextRandomCommand}" HorizontalAlignment="Center" Margin="0,28,0,0" />
                    </StackPanel>
                </Grid>

                <!-- Поиск -->
                <Grid Visibility="{Binding IsSearch, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Поиск" Style="{StaticResource HeadingText}" Margin="0,0,0,18" />

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource SearchBoxStyle}"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1" Content="Найти" Style="{StaticResource AccentButtonStyle}"
                                Command="{Binding SearchCommand}" Margin="12,0,0,0" />
                    </Grid>

                    <TextBlock Grid.Row="2" Text="{Binding SearchStatus}" Style="{StaticResource SubText}"
                               Margin="2,16,0,10" />

                    <ListBox Grid.Row="3" ItemsSource="{Binding SearchResults}" Style="{StaticResource CardListStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12" Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Text}" Style="{StaticResource BodyText}" />
                                        <TextBlock Text="{Binding Author}" Style="{StaticResource AuthorText}"
                                                   FontSize="14" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- Игра -->
                <Grid Visibility="{Binding IsGame, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Угадай автора" Style="{StaticResource HeadingText}" Margin="0,0,0,18" />

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel MaxWidth="700" HorizontalAlignment="Left">
                            <Border Style="{StaticResource CardStyle}" Padding="28"
                                    Visibility="{Binding HasGameQuote, Converter={StaticResource BoolToVis}}">
                                <TextBlock Style="{StaticResource QuoteText}" FontSize="20">
                                    <Run Text="“" /><Run Text="{Binding GameQuote.Text}" /><Run Text="”" />
                                </TextBlock>
                            </Border>

                            <ItemsControl ItemsSource="{Binding GameOptions}" Margin="0,18,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding}" Style="{StaticResource OptionButtonStyle}"
                                                HorizontalAlignment="Stretch"
                                                Command="{Binding DataContext.AnswerCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                IsEnabled="{Binding DataContext.CanAnswer, RelativeSource={RelativeSource AncestorType=Window}}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="{Binding GameFeedback}" Style="{StaticResource BodyText}"
                                       FontWeight="Bold" Margin="2,20,0,0" />
                            <Button Content="Следующий вопрос" Style="{StaticResource AccentButtonStyle}"
                                    Command="{Binding NewGameCommand}" HorizontalAlignment="Left" Margin="0,20,0,0" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- Библиотека -->
                <Grid Visibility="{Binding IsLibrary, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Style="{StaticResource HeadingText}" Margin="0,0,0,18">
                        <Run Text="Библиотека" />
                    </TextBlock>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Library}" Style="{StaticResource CardListStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12" Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Text}" Style="{StaticResource BodyText}" />
                                        <TextBlock Text="{Binding Author}" Style="{StaticResource AuthorText}"
                                                   FontSize="14" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- Настройки -->
                <Grid Visibility="{Binding IsSettings, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Настройки" Style="{StaticResource HeadingText}" Margin="0,0,0,18" />

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel MaxWidth="660" HorizontalAlignment="Left">

                            <Border Style="{StaticResource CardStyle}" Padding="28">
                                <StackPanel>
                                    <TextBlock Text="Обновление цитат" Style="{StaticResource BodyText}"
                                               FontWeight="Bold" FontSize="17" />
                                    <TextBlock Style="{StaticResource SubText}" Margin="0,8,0,0" TextWrapping="Wrap"
                                               Text="Загрузить свежие цитаты из ZenQuotes API. Новые добавятся в базу, дубликаты отсеются. Загрузка идёт в фоне — приложением можно пользоваться." />

                                    <TextBlock Text="Запросов за одно обновление" Style="{StaticResource SubText}" Margin="0,16,0,0" />
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <Slider Minimum="1" Maximum="10" TickFrequency="1" IsSnapToTickEnabled="True"
                                                Width="260" VerticalAlignment="Center"
                                                Value="{Binding BatchCount, Mode=TwoWay}" />
                                        <TextBlock Text="{Binding BatchCount}" Style="{StaticResource AuthorText}"
                                                   FontSize="20" Margin="18,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Style="{StaticResource SubText}" Margin="0,10,0,0" TextWrapping="Wrap"
                                               Text="Каждый запрос — ~50 цитат. Без ключа между запросами пауза ~6 c, чтобы не упереться в лимит ZenQuotes." />

                                    <TextBlock Style="{StaticResource SubText}" Margin="0,16,0,0">
                                        <Run Text="{Binding SourceLabel, Mode=OneWay}" />
                                        <Run Text="   •   " />
                                        <Run Text="{Binding QuoteCount, Mode=OneWay}" />
                                        <Run Text=" цитат" />
                                    </TextBlock>
                                    <Button Content="⟳ Обновить" Style="{StaticResource AccentButtonStyle}"
                                            Command="{Binding RefreshCommand}" HorizontalAlignment="Left"
                                            Margin="0,18,0,0" Padding="20,9" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}" Padding="28" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="API-ключ ZenQuotes (необязательно)" Style="{StaticResource BodyText}"
                                               FontWeight="Bold" FontSize="17" />
                                    <TextBox Style="{StaticResource SearchBoxStyle}" Margin="0,12,0,0"
                                             Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource SubText}" Margin="0,12,0,0" TextWrapping="Wrap">
                                        <Run Text="Ключ платный. Без него приложение работает с паузами между запросами. Получить ключ: " />
                                        <Hyperlink NavigateUri="https://zenquotes.io/pricing"
                                                   RequestNavigate="Hyperlink_RequestNavigate"
                                                   Foreground="{StaticResource AccentBrush}">
                                            <Run Text="zenquotes.io/pricing" />
                                        </Hyperlink>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal" Margin="0,16,0,16">
                                <Button Content="Сохранить настройки" Style="{StaticResource AccentButtonStyle}"
                                        Command="{Binding SaveSettingsCommand}" />
                                <TextBlock Text="{Binding SettingsStatus}" Style="{StaticResource SubText}"
                                           VerticalAlignment="Center" Margin="16,0,0,0" />
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>

            </Grid>
        </Grid>

        <!-- Статус-бар -->
        <Border Grid.Row="2" Background="{StaticResource CardBrush}" Padding="20,12">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Style="{StaticResource SubText}" VerticalAlignment="Center">
                    <Run Text="{Binding SourceLabel, Mode=OneWay}" />
                    <Run Text="   •   " />
                    <Run Text="{Binding QuoteCount, Mode=OneWay}" />
                    <Run Text=" цитат" />
                </TextBlock>

                <Button DockPanel.Dock="Right" Content="Отмена" Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding CancelCommand}" VerticalAlignment="Center" Margin="0,0,4,0"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
                <TextBlock DockPanel.Dock="Right" Text="Загрузка..." Foreground="{StaticResource AccentBrush}"
                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,16,0"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
                <TextBlock DockPanel.Dock="Right" Text="{Binding StatusDetail}" Style="{StaticResource SubText}"
                           VerticalAlignment="Center" Margin="0,0,16,0" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
